# Mikroservis url leri
BOOK_SERVICE_URL=http://book-service:8001
BORROW_SERVICE_URL=http://borrow-service:8000
AUTH_SERVICE_URL=http://auth-service:8002

# MongoDB Bağlantıları (Her servis kendi DB'sine baksın)
# Format: mongodb://kullanıcı:şifre@servis-adı:port
AUTH_MONGODB_URL=mongodb://auth-db:27017/auth_db
BOOK_MONGODB_URL=mongodb://book-db:27017/book_db
BORROW_MONGODB_URL=mongodb://borrow-db:27017/borrow_db

# Redis Ayarları (Token saklama için tek bir Redis yeterli)
REDIS_HOST=redis-cache
REDIS_PORT=6379

